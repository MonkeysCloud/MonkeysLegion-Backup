{
    "name": "monkeyscloud/monkeyslegion-backup",
    "description": "Framework-agnostic database backup and restore library for PHP 8.4+. Supports MySQL, Postgres, MongoDB, Redis, SQLite, local filesystem, S3, and GCS.",
    "type": "library",
    "keywords": ["backup", "restore", "database", "mysql", "postgres", "mongodb", "redis", "sqlite", "s3", "gcs", "cli"],
    "homepage": "https://github.com/monkeyscloud/MonkeysLegion-Backup",
    "license": "MIT",
    "authors": [
        {
            "name": "MonkeysCloud Team",
            "email": "jorge@monkeyscloud.com",
            "homepage": "https://monkeyscloud.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "MonkeysLegion\\Backup\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MonkeysLegion\\Backup\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "google/cloud-storage": "^2.3",
        "aws/aws-sdk-php": "^3.387",
        "monkeyscloud/monkeyslegion-cli": "^2.0",
        "monkeyscloud/monkeyslegion-di": "^2.0",
        "monkeyscloud/monkeyslegion-logger": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "phpstan/phpstan": "^2.2"
    },
    "scripts": {
        "test":             "vendor/bin/phpunit --testsuite Unit",
        "test:all":         "vendor/bin/phpunit",
        "test:gcs":         "vendor/bin/phpunit --group gcs",
        "test:s3":          "vendor/bin/phpunit --group s3",
        "test:mysql":       "vendor/bin/phpunit --group mysql",
        "test:pgsql":       "vendor/bin/phpunit --group pgsql",
        "test:db":          "vendor/bin/phpunit --group db",
        "test:integration": "vendor/bin/phpunit --group gcs,s3,db",
        "stan":             "vendor/bin/phpstan analyse"
    }
}
