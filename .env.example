# MonkeysLegion Backup — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_TEST_DB_DUMP=mb_test_dump
MYSQL_TEST_DB_RESTORE=mb_test_restore

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_USER=postgres
PGSQL_PASSWORD=
PGSQL_TEST_DB_DUMP=mb_test_dump
PGSQL_TEST_DB_RESTORE=mb_test_restore

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_TEST_DB=mb_test_mongo

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Optional — leave blank to use the Redis default (no-auth) user.
# To test ACL-authenticated dumps, create a user first:
#   redis-cli ACL SETUSER backupuser on ">yourpassword" "~*" "+@all"
REDIS_USER=
REDIS_PASSWORD=
