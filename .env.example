# MonkeysLegion Backup — Environment Configuration
#
# Integration tests (recommended — all values match docker-compose.testing.yml):
#   docker compose -f docker-compose.testing.yml up -d --wait
#   cp .env.testing .env
#   composer test:all
#
# Or copy this file and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# MySQL  (docker-compose service: mysql)
# ---------------------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_TEST_DB_DUMP=mb_test_dump
MYSQL_TEST_DB_RESTORE=mb_test_restore

# ---------------------------------------------------------------------------
# PostgreSQL  (docker-compose service: postgres)
# ---------------------------------------------------------------------------
PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_USER=postgres
PGSQL_PASSWORD=secret
PGSQL_TEST_DB_DUMP=mb_test_dump
PGSQL_TEST_DB_RESTORE=mb_test_restore

# ---------------------------------------------------------------------------
# MongoDB  (docker-compose service: mongodb)
# ---------------------------------------------------------------------------
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_TEST_DB=mb_test_mongo

# ---------------------------------------------------------------------------
# Redis  (docker-compose service: redis — host port 6380)
# ---------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
# ACL user created automatically by redis-init in docker-compose.testing.yml.
REDIS_USER=backupuser
REDIS_PASSWORD=analikayn
